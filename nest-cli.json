{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/ticket-platform/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/ticket-platform/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/ticket-platform",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "events": {
      "type": "library",
      "root": "libs/events",
      "entryFile": "index",
      "sourceRoot": "libs/events/src",
      "compilerOptions": {
        "tsConfigPath": "libs/events/tsconfig.lib.json"
      }
    },
    "kafka": {
      "type": "library",
      "root": "libs/kafka",
      "entryFile": "index",
      "sourceRoot": "libs/kafka/src",
      "compilerOptions": {
        "tsConfigPath": "libs/kafka/tsconfig.lib.json"
      }
    },
    "ticket-platform": {
      "type": "application",
      "root": "apps/ticket-platform",
      "entryFile": "main",
      "sourceRoot": "apps/ticket-platform/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ticket-platform/tsconfig.app.json"
      }
    },
    "ticket-service": {
      "type": "application",
      "root": "apps/ticket-service",
      "entryFile": "main",
      "sourceRoot": "apps/ticket-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ticket-service/tsconfig.app.json"
      }
    }
  }
}